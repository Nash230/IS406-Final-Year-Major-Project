        <mxCell id="1" parent="0" />
        <mxCell id="cEwKnniIvriUS2pvK32b-1" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;font face=&quot;Verdana&quot;&gt;User (parent or secondary student account)&lt;br&gt;+ userID (PK)&lt;br&gt;+ firstName&lt;br&gt;+ lastName&lt;br&gt;+ email&lt;br&gt;+ password&lt;br&gt;+ role (parent / secondary_student)&lt;br&gt;+ created_at&lt;br&gt;&#x9;Learner (child profile linked to a parent, or self for secondary students)&lt;br&gt;+ learnerID (PK)&lt;br&gt;+ userID (FK)&lt;br&gt;+ dateOfBirth&lt;br&gt;+ gradeLevel&lt;br&gt;+ gradeBand (elementary/primary/secondary)&lt;br&gt;&lt;br&gt;Subject&lt;br&gt;+ subjectID (PK)&lt;br&gt;+ subjectName&lt;br&gt;+ gradeLevel/band&lt;br&gt;+ strands&lt;br&gt;&#x9;CurriculumTopic (syllabus data layer)&lt;br&gt;+ topicID (PK)&lt;br&gt;+ subjectID (FK)&lt;br&gt;+ topicName&lt;br&gt;+ contentStandard&lt;br&gt;+ gradeLevel&lt;br&gt;&lt;br&gt;SearchKeyword (keyword bridge layer)&lt;br&gt;+ keywordID (PK)&lt;br&gt;+ topicID (FK)&lt;br&gt;+ keyword&lt;br&gt;&lt;/font&gt;&lt;div&gt;&lt;font face=&quot;Verdana&quot;&gt;+ targetPlatform (youtube / khan_academy / phet / oer)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Verdana&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;font face=&quot;Verdana&quot;&gt;&#x9;LearningResource (retrieved via API or manually curated)&lt;br&gt;+ resourceID (PK)&lt;br&gt;+ topicID (FK)&lt;br&gt;+ title&lt;br&gt;+ resource_type (video/simulation / exercise / link)&lt;br&gt;+ sourcePlatform&lt;br&gt;+ externalURL&lt;br&gt;+ isCurated (boolean — true for PhET/OER manually linked resources)&lt;br&gt;&lt;br&gt;LearningActivity (activity/progress data layer)&lt;br&gt;+ activityID (PK)&lt;br&gt;+ learnerID (FK)&lt;br&gt;+ topicID (FK)&lt;br&gt;+ assignedBy (user_id FK — null if self-assigned)&lt;br&gt;+ scheduledDate&lt;br&gt;&lt;/font&gt;&lt;div&gt;&lt;font face=&quot;Verdana&quot;&gt;+ status (pending / completed)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Verdana&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;font face=&quot;Verdana&quot;&gt;&#x9;Progress&lt;br&gt;+ progressID (PK)&lt;br&gt;+ learnerID (FK)&lt;br&gt;+ quizID (FK)&lt;br&gt;+ quizScore&lt;br&gt;+ completionDate&lt;br&gt;&lt;br&gt;AIRecommendation&lt;br&gt;+ recommendationID (PK)&lt;br&gt;+ learnerID (FK)&lt;br&gt;+ topicID (FK)&lt;br&gt;+ recommendedResourceID (FK)&lt;br&gt;+ recommendationReason&lt;br&gt;&lt;/font&gt;&lt;div&gt;&lt;font face=&quot;Verdana&quot;&gt;+ createdAt&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Verdana&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;font face=&quot;Verdana&quot;&gt;&#x9;Quiz &lt;br&gt;+ quizID (PK)&lt;br&gt;+ topicID (FK)&lt;br&gt;+ title&lt;br&gt;&lt;br&gt;QuizQuestion&lt;br&gt;+ quizQuestionID (PK)&lt;br&gt;+ quizID (FK)&lt;br&gt;+ quizText&lt;br&gt;+ correctAnswer&lt;br&gt;+ quizScore&lt;/font&gt;" vertex="1">
          <mxGeometry height="1280" width="270" x="60" y="20" as="geometry" />
        </mxCell>
